# =============================================================================
# Backend environment template — SAFE TO COMMIT.
#
# This file is the canonical example. Real secrets live in backend/.env, which
# is git-ignored and MUST NEVER be committed.
#
# Local setup:
#   1. cp backend/.env.example backend/.env
#   2. Open backend/.env and replace YOUR_MAC_USERNAME in DATABASE_URL with
#      your local macOS / PostgreSQL role name (often the same as `whoami`).
#   3. Make sure PostgreSQL, Redis, and Ollama are running locally.
#   4. Start the backend, then curl GET /health/dependencies to verify.
#
# Privacy rules (these defaults exist for a reason — do not flip them
# casually):
#   * STORE_USER_QUESTIONS must stay `false` by default. Immigration questions
#     can include highly sensitive personal facts (asylum, visa overstay, ICE
#     encounters, family / criminal history, removal proceedings, etc.). We
#     do not store the full user question text or the full generated answer
#     text by default.
#   * Public legal-source data (USCIS / eCFR / INA / BIA / Federal Register
#     text, citations, chunks, embeddings) CAN be stored and committed via
#     migrations / seed scripts.
#   * Real user questions and full generated answers MUST NOT be stored or
#     committed. Only privacy-safe metadata may live in `privacy_safe_answer_logs`.
#   * Real user queries are processed by LOCAL models only (Ollama / vLLM).
#     No OpenAI / Anthropic / public AI API keys belong in this file.
# =============================================================================

# ---- App identity -----------------------------------------------------------
APP_NAME="Immigration Law Guidance App"
APP_ENV="development"
APP_DEBUG=true

# ---- PostgreSQL -------------------------------------------------------------
# SQLAlchemy-style URL (driver = psycopg v3). The backend normalizes this to
# `postgresql://...` internally when talking to libpq, so this single form
# works for both SQLAlchemy and the psycopg-based health check.
# Replace YOUR_MAC_USERNAME with your local PostgreSQL role (often `whoami`).
DATABASE_URL="postgresql+psycopg://YOUR_MAC_USERNAME@localhost:5432/immigration_law_dev"

# ---- Redis ------------------------------------------------------------------
REDIS_URL="redis://localhost:6379/0"

# ---- Ollama (local LLM + embeddings) ---------------------------------------
# Default Ollama port on macOS. Used for embeddings and local LLM inference.
# No public AI API is ever called by this backend.
OLLAMA_BASE_URL="http://localhost:11434"

# Optional. Use this when chat generation should use a different Ollama endpoint than embeddings.
# Example for Ollama Cloud: https://ollama.com
# Leave blank to use OLLAMA_BASE_URL for both embeddings and chat.
OLLAMA_CHAT_BASE_URL=

# Optional. Chat model used by /api/chat.
# For Ollama Cloud, set this to a model available in your Ollama Cloud account, such as gemma3:4b.
OLLAMA_CHAT_MODEL=llama3.1:8b

# Optional. Required only for Ollama Cloud/private authenticated endpoints.
# Leave blank for local Ollama (the default). Never commit a real value here.
OLLAMA_API_KEY=

# ---- Privacy switch ---------------------------------------------------------
# Keep this FALSE. Enabling it would allow the backend to persist full user
# question text and full generated answer text, which violates the project's
# privacy-first design. Leave it false unless you have an explicit, reviewed
# reason to change it.
STORE_USER_QUESTIONS=false
