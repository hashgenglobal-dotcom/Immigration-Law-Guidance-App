{
  "version": "mvp-golden-v1",
  "description": "Golden retrieval queries for MVP citation quality tuning. Matchers use flexible substring/prefix rules — not exact rank-1 strings only.",
  "top_k": 5,
  "accept_top3_rate": 0.85,
  "queries": [
    {
      "id": "asylum_ead",
      "query": "Can asylum applicants get work authorization?",
      "category": "asylum_ead",
      "expects_clarification": false,
      "match_any": ["208.7", "208.13"],
      "notes": "Primary asylum EAD regulation; 274a.13 may also appear in top 3."
    },
    {
      "id": "nta_definition",
      "query": "What is a Notice to Appear?",
      "category": "nta_removal",
      "expects_clarification": false,
      "match_any": ["239.1", "239.2", "1239.1"],
      "notes": "Removal NTA sections; BIA decisions deprioritized for definitional queries."
    },
    {
      "id": "aos_definition",
      "query": "What is adjustment of status?",
      "category": "aos_i485",
      "expects_clarification": false,
      "match_any": ["1245.1", "245.1", "I-485"],
      "notes": "AOS eligibility or Form I-485 chunk."
    },
    {
      "id": "gmc_naturalization",
      "query": "What is good moral character for naturalization?",
      "category": "naturalization",
      "expects_clarification": false,
      "match_any": ["316.10", "Vol 12"],
      "notes": "CFR GMC or USCIS Policy Manual Vol 12."
    },
    {
      "id": "ead_apply_broad",
      "query": "How do I apply for EAD?",
      "category": "ead_i765",
      "expects_clarification": true,
      "match_any": ["I-765", "274a.", "217.2", "Vol 10"],
      "notes": "Broad query — chat may return needs_clarification before retrieval; retrieval still tested for diverse EAD sources."
    },
    {
      "id": "stem_opt",
      "query": "What is STEM OPT?",
      "category": "opt_stem",
      "expects_clarification": false,
      "match_any": ["214.2", "217."],
      "notes": "F-1 OPT/STEM regulatory sections."
    },
    {
      "id": "travel_aos_pending",
      "query": "Can I travel while I-485 is pending?",
      "category": "advance_parole",
      "expects_clarification": false,
      "match_any": ["1245.13", "1245.15", "parole", "Vol 3", "I-131"],
      "notes": "Advance parole / pending AOS travel guidance."
    },
    {
      "id": "advance_parole",
      "query": "What is advance parole?",
      "category": "advance_parole",
      "expects_clarification": false,
      "match_any": ["1245.13", "parole", "Vol 3"],
      "notes": "Advance parole definition."
    },
    {
      "id": "rfe",
      "query": "What is an RFE?",
      "category": "case_admin",
      "expects_clarification": false,
      "match_any": ["Part L", "RFE", "request for evidence"],
      "notes": "USCIS PM request-for-evidence chapters."
    },
    {
      "id": "address_change",
      "query": "How do I change my address with USCIS?",
      "category": "case_admin",
      "expects_clarification": false,
      "match_any": ["Official Page", "265.", "address", "Part A, Ch 10"],
      "notes": "USCIS address change official page or COA policy."
    },
    {
      "id": "form_i130",
      "query": "What is Form I-130?",
      "category": "family_i130",
      "expects_clarification": false,
      "match_any": ["I-130"],
      "notes": "USCIS Form I-130 official page."
    },
    {
      "id": "form_i864",
      "query": "What is Form I-864?",
      "category": "affidavit_i864",
      "expects_clarification": false,
      "match_any": ["I-864", "213a"],
      "notes": "Affidavit of support form or INA/CFR support provisions."
    },
    {
      "id": "tps_ead",
      "query": "Can TPS holders get work authorization?",
      "category": "tps_daca_ead",
      "expects_clarification": false,
      "match_any": ["244.", "274a.12", "TPS"],
      "notes": "TPS employment authorization."
    }
  ]
}
