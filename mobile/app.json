{
  "expo": {
    "name": "SourcePath",
    "slug": "sourcepath",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "sourcepath",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/images/sourcepath-icon-shield-torch-digital.png",
    "splash": {
      "backgroundColor": "#1F2839",
      "resizeMode": "contain",
      "image": "./assets/images/sourcepath-icon-shield-torch-digital.png"
    },
    "backgroundColor": "#1F2839",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hashgen.immigrationlawguidance"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/sourcepath-icon-shield-torch-digital.png",
        "backgroundColor": "#1F2839"
      },
      "package": "com.hashgen.immigrationlawguidance"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1F2839"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
