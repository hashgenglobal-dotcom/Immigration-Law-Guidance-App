{
  "expo": {
    "name": "SourcePath",
    "slug": "sourcepath",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "sourcepath",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1F2839"
    },
    "backgroundColor": "#F4F0E6",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hashgen.immigrationlawguidance"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1F2839"
      },
      "package": "com.hashgen.immigrationlawguidance"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
